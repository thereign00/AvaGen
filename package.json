{
  "name": "avagen",
  "version": "0.3.2",
  "private": true,
  "description": "Local pipeline platform for avatar-fronted documentary YouTube videos — HeyGen photo avatar + ElevenLabs voiceover, illustrated with real internet footage / AI b-roll (Ken Burns on stills).",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "desktop": "electron .",
    "app": "electron .",
    "predist": "npm run build && node scripts/prepare-electron.mjs",
    "dist": "electron-builder --win",
    "build:exe": "npm run dist",
    "release": "npm run predist && electron-builder --win --publish always",
    "postinstall": "node scripts/fix-native-binaries.mjs",
    "fix-bins": "node scripts/fix-native-binaries.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^171.4.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^34.0.0",
    "electron-builder": "^26.15.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
